# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# docs/08 §5. Production uses Docker secrets / vault, not a committed .env.

# --- Datastore credentials (local dev placeholders) ---
PG_PASSWORD=change-me
MINIO_USER=hasa
MINIO_PASSWORD=change-me

# --- Auth (core/auth) ---
# RS256/ES256 public key used by services to VERIFY JWTs (PEM, single line with \n
# or mounted file). Tokens are signed by the auth issuer, not by these services.
# Leave empty for local dev with HS256 (JWT_SECRET) instead.
JWT_PUBLIC_KEY=
JWT_SECRET=

# --- LLM gateway (not needed for Sprint 0 infra) ---
LLM_PROFILE=local                                   # local | external_deidentified | dev
LLM_BACKEND=mlx                                     # mlx (Mac: LM Studio / mlx-lm) | vllm (server)
# The model runs on the Mac HOST; Docker services reach it via host.docker.internal.
# Local dev default here is LM Studio on port 1234 (see docs/08 §2b). mlx-lm/vLLM use 8000.
# From a HOST process (pytest/scripts, not in Docker) use http://localhost:1234/v1 instead.
LLM_GATEWAY_BASE_URL=http://host.docker.internal:1234/v1
OPENROUTER_API_KEY=                                 # leave empty in production
PRIMARY_MODEL=qwen3.6-35b-a3b                       # API model id the server exposes (GET /v1/models)
# Optional gateway tunables (sensible defaults if unset):
LLM_TEMPERATURE=0                                   # LLM explains, never decides — keep low
LLM_TIMEOUT_SECONDS=60

# --- Versioning ---
RULESET_VERSION=2026.06.0
