# --- Secrets / local config (NEVER commit) ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Virtualenvs ---
.venv/
venv/
env/

# --- Model caches / weights (never in git; see CLAUDE.md) ---
models/cache/
*.gguf
*.safetensors
*.bin
.cache/
huggingface/

# --- Training checkpoints / artifacts (docs/16; versioned on disk, not in git) ---
checkpoints/
reports/

# --- Docker volume data (if ever bind-mounted locally) ---
pgdata/
qdrant_storage/
minio_data/

# --- Large datasets (download/fetch separately; keep only README/manifests) ---
# See docs/13_Datasets.md. Ignore everything under datasets/, then re-allow the
# per-dataset README so provenance/license/fetch-instructions stay in git.
datasets/**
!datasets/*/
!datasets/*/README.md

# --- OS / editor ---
.DS_Store
*.swp
.idea/
.vscode/
volumes/
some_commands.txt
